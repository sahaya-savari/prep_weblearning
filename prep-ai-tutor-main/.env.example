# PrepMind AI — Frontend Environment Variables
# Copy this to .env and fill in your values — NEVER commit .env

# Backend API URL
# Local development:
VITE_API_URL=http://localhost:5000
# Production (set this to your deployed backend URL):
# VITE_API_URL=https://prepmind-backend.onrender.com

# Google reCAPTCHA v2 site key (frontend)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key_here
