# PrepMind AI — Backend Environment Variables
# Copy this to .env and fill in your values

PORT=5000

# Gemini API — get your FREE key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (optional local fallback) — install from https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
