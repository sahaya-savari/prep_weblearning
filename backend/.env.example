# PrepMind AI — Backend Environment Variables
# Copy this to .env and fill in your values — NEVER commit .env

# ── Server ────────────────────────────────
PORT=5000

# ── Google Gemini AI (REQUIRED) ───────────
# Get your FREE key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── CORS (Production only) ────────────────
# Set this to your frontend URL when deployed.
# Comma-separated if multiple:
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Ollama (Optional local fallback) ──────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── GitHub OAuth ──────────────────────────
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set callback URL to: https://prepmind-backend-bfkw.onrender.com/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── Google OAuth ──────────────────────────
# Create app at: https://console.cloud.google.com/
# Callback URL:  https://prepmind-backend-bfkw.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Session ────────────────────────────────
# Use a long random string in production
SESSION_SECRET=your_random_session_secret_here
